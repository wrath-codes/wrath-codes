{
  "name": "wrath-codes",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter @wrath-codes/web dev",
    "build": "bun run --filter @wrath-codes/web build",
    "preview": "bun run --filter @wrath-codes/web preview",
    "check": "bun run --filter @wrath-codes/web check",
    "test": "bun run --filter '*' test",
    "lint": "bunx @biomejs/biome check .",
    "lint:fix": "bunx @biomejs/biome check --write .",
    "format": "bunx @biomejs/biome format --write ."
  }
}
